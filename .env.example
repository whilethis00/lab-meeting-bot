# =============================================
# 랩미팅 봇 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 이름 바꾼 후 값을 채우세요
# =============================================

# [필수] 텔레그램 봇 토큰
# 발급 방법: 텔레그램에서 @BotFather 검색 → /newbot → 이름 설정 → 토큰 복사
TELEGRAM_BOT_TOKEN=여기에_텔레그램_봇_토큰_붙여넣기

# [필수] Anthropic API 키 (Claude AI)
# 발급 방법: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=여기에_ANTHROPIC_API_키_붙여넣기

# [자동] 데이터베이스 경로 (수정 불필요)
DATABASE_PATH=./data/meetings.db

# [자동] 회의록 저장 폴더 (수정 불필요)
LABMEETING_PATH=./labmeeting

# [선택] Google Calendar 자격증명 파일 경로
# 캘린더 기능 사용 시 설정 (설치 안내문 참조)
GOOGLE_CALENDAR_CREDENTIALS=./credentials.json

# [선택] 로그 레벨 (INFO / DEBUG)
LOG_LEVEL=INFO
